# Used by the golang-migrate CLI (make migrate-up / migrate-down), not by the app itself
# which uses it directly as the DSN if set, otherwise falls back to DB_* below.
DATABASE_URL=postgres://gobooking:gobooking@localhost:5432/gobooking?sslmode=disable

APP_ENV=development
APP_PORT=8080

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

JWT_SECRET=