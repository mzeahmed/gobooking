# Used by the app directly as the DSN if set, otherwise falls back to DB_* below.
DATABASE_URL=postgres://gobooking:gobooking@localhost:5432/gobooking?sslmode=disable

# Used by the goose CLI (make migrate-up / migrate-down / migrate-create), which
# runs on the host machine, outside Docker.
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://gobooking:gobooking@localhost:5432/gobooking?sslmode=disable
GOOSE_MIGRATION_DIR=api/internal/adapters/postgresql/migrations

APP_ENV=development
APP_PORT=8080

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

JWT_SECRET=